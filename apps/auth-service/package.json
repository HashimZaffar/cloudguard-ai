    "winston": "^3.17.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
